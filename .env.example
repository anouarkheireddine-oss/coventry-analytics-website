# ── ACAN Environment Variables ─────────────────────────────────────────────
# Copy this file to .env.local and fill in values to activate each layer.

# Site URL (used in canonical URLs and sitemap)
NEXT_PUBLIC_BASE_URL=https://ukpaycheck.co.uk

# ── Layer 1: Rich content generation (activate the Claude content engine)
# Get your key at console.anthropic.com
ANTHROPIC_API_KEY=

# ── Layer 2: Ad monetisation (activate Google AdSense units)
# Find your publisher ID in AdSense dashboard: ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_ID=
